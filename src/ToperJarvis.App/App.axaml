<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ToperJarvis.App.App"
             xmlns:local="using:ToperJarvis.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon Icon="/Assets/avalonia-logo.ico" ToolTipText="ToperJarvis"
                      Clicked="OnTrayShow">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Pokaż" Click="OnTrayShow"/>
                        <NativeMenuItem Header="Pełny ekran" Click="OnTrayFullscreen"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Wyjście" Click="OnTrayExit"/>
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
